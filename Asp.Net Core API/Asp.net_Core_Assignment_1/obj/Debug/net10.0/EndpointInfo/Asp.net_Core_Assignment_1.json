{
  "openapi": "3.0.1",
  "info": {
    "title": "HealthCareAPI",
    "version": "v1"
  },
  "paths": {
    "/api/auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequestDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequestDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequestDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/Doctor/GetAllDoctors": {
      "get": {
        "tags": [
          "Doctor"
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/Doctor/AddDoctor": {
      "post": {
        "tags": [
          "Doctor"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DoctorCreateDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/DoctorCreateDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/DoctorCreateDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/Doctor/GetDoctor/{Specialization}": {
      "get": {
        "tags": [
          "Doctor"
        ],
        "parameters": [
          {
            "name": "Specialization",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/Doctor/DeleteDoctor/{id}": {
      "delete": {
        "tags": [
          "Doctor"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/Patient/GetAllPatients": {
      "get": {
        "tags": [
          "Patient"
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/Patient/GetPatient/{id}": {
      "get": {
        "tags": [
          "Patient"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/Patient/AddPatient": {
      "post": {
        "tags": [
          "Patient"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PatientCreateDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/PatientCreateDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/PatientCreateDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/Patient/Update/{id}": {
      "patch": {
        "tags": [
          "Patient"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PatientUpdateDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/PatientUpdateDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/PatientUpdateDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/Patient/Delete/{id}": {
      "delete": {
        "tags": [
          "Patient"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/prescription/Appointment/{appoinmentId}": {
      "get": {
        "tags": [
          "Prescription"
        ],
        "parameters": [
          {
            "name": "appoinmentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/prescription/AddAppointment": {
      "post": {
        "tags": [
          "Prescription"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PrescriptionCreateDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/PrescriptionCreateDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/PrescriptionCreateDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "DoctorCreateDto": {
        "required": [
          "name",
          "specialization"
        ],
        "type": "object",
        "properties": {
          "name": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string"
          },
          "specialization": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string"
          },
          "experience": {
            "maximum": 60,
            "minimum": 0,
            "type": "integer",
            "format": "int32"
          },
          "consultationFee": {
            "maximum": 100000,
            "minimum": 0,
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "LoginRequestDto": {
        "required": [
          "password",
          "userName"
        ],
        "type": "object",
        "properties": {
          "userName": {
            "minLength": 1,
            "type": "string"
          },
          "password": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "PatientCreateDto": {
        "required": [
          "contactNumber",
          "gender",
          "name"
        ],
        "type": "object",
        "properties": {
          "name": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string"
          },
          "age": {
            "maximum": 120,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "gender": {
            "maxLength": 20,
            "minLength": 1,
            "type": "string"
          },
          "contactNumber": {
            "minLength": 1,
            "pattern": "^[5-9][0-9]{9}$",
            "type": "string"
          },
          "address": {
            "maxLength": 250,
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "PatientUpdateDto": {
        "required": [
          "contactNumber"
        ],
        "type": "object",
        "properties": {
          "age": {
            "maximum": 120,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "contactNumber": {
            "minLength": 1,
            "pattern": "^[5-9][0-9]{9}$",
            "type": "string"
          },
          "address": {
            "maxLength": 250,
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "PrescriptionCreateDto": {
        "required": [
          "appointmentId",
          "diagonsis",
          "medicines"
        ],
        "type": "object",
        "properties": {
          "appointmentId": {
            "type": "integer",
            "format": "int32"
          },
          "diagonsis": {
            "maxLength": 200,
            "minLength": 1,
            "type": "string"
          },
          "medicines": {
            "maxLength": 500,
            "minLength": 1,
            "type": "string"
          },
          "notes": {
            "maxLength": 500,
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "description": "Enter: Bearer {your token}",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    {
      "Bearer": [ ]
    }
  ]
}